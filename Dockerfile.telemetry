FROM node:22-alpine

# Install FFmpeg for stream extraction
RUN apk add --no-cache ffmpeg

WORKDIR /app

# Copy package files and install dependencies
COPY package*.json ./
RUN npm install --production

# Copy the bridge application
COPY telemetry_bridge.js .

# Expose the WebSocket port
EXPOSE 8081

# Run the bridge
CMD ["node", "telemetry_bridge.js"]
